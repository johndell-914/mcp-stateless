# Copy to .env (which is gitignored) and fill in real values. NEVER commit .env.
#   cp .env.example .env

# --- Supabase Postgres ---
# SESSION-mode pooler URI (host contains "pooler", port 5432). Copy it from the
# Supabase dashboard "Connect" panel and paste your DB password in place of [PASSWORD].
# Do NOT use the Direct connection (IPv6-only, often unreachable) or the Transaction
# pooler (port 6543 — breaks asyncpg prepared statements).
DATABASE_URL=postgresql://postgres.PROJECT_REF:[PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres

# --- App secret ---
# HMAC key that signs cart_token handles.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
TOKEN_SECRET=

# --- set in later build phases; leave as-is for now ---
# INSTANCE_ID=server-a
# STATELESS_MODE=1
# UPSTREAMS=http://localhost:9001,http://localhost:9002
# STICKY=0
# PROXY_URL=http://localhost:9000/mcp
# UI_AUTH=demo:demo
